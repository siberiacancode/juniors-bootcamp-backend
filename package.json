{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npx @nestjs/cli start --watch",
    "build": "npx @nestjs/cli build",
    "docker-compose": "docker compose -p juniors-bootcamp-backend up --build",
    "dev-debug": "nest start --debug --watch",
    "prod": "node dist/main",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.(ts|js)\"",
    "pretty": "yarn format && yarn lint",
    "lint-inspector": "npx @eslint/config-inspector",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@scalar/nestjs-api-reference": "^1.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "generate-password": "^1.7.1",
    "graphql": "^16.13.2",
    "graphql-subscriptions": "^3.0.0",
    "hbs": "^4.2.0",
    "mongoose": "9.3.3",
    "nestjs-i18n": "^10.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@siberiacancode/eslint": "^2.16.12",
    "@siberiacancode/prettier": "^1.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write"
    ],
    "*.ts": [
      "prettier --write",
      "eslint --no-error-on-unmatched-pattern --fix"
    ]
  }
}
