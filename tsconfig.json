{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "incremental": true,
    "target": "es2017",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "paths": {
      "@/*": ["./src/*"]
    },
    "declaration": true,
    "outDir": "./dist",
    "removeComments": true,
    "sourceMap": true,

    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
